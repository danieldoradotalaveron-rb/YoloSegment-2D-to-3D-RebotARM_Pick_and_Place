# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
**/.venv/
venv/
env/

# Trained weights and training runs (excluded on purpose)
runs/
**/runs/
*.pt
*.engine
*.onnx
*.pth

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# ROS 2 / colcon build artifacts (regenerated by `colcon build`)
build/
install/
log/
**/COLCON_IGNORE

# Misc outputs
outputs/
*.log

# YOLO dataset caches (regenerated automatically)
*.cache

# Heavy media under docs/ (track the Markdown, not example renders / point clouds)
docs/**/*.png
docs/**/*.jpg
docs/**/*.jpeg
docs/**/*.ply
docs/**/*.pcd
# ...but keep README/doc figures under docs/img/.
!docs/img/**

# Generated local config
.generated/

# Hand-eye calibration captures + validation output (keep the code, not the raw data)
handeye/**/captures/
handeye/validation_base_frame.json

# Scratch notes
NOTES.md

# External experiments / vendored repos (Depth-Anything-3 has its own .git;
# spike outputs are large binaries). Not part of the runtime; keep out of the repo.
external/

# Hugging Face staging (cards/media for the HF model & dataset repos; kept local).
hf_model/
hf_dataset/

# Dataset images are hosted on Hugging Face (see README), not shipped in git.
# Files stay on disk so the local pipeline keeps working.
DS/dataset_raw/
DS/dataset_labeled/
DS/dataset_labeled_point/

# Converted YOLO-seg dataset (build artifact; fully regenerated by `just convert`,
# which wipes and recreates the folder, so no .gitkeep is kept here).
DS/dataset_yolo/

# Capture staging (transient). Keep folder structure only.
DS/dataset_capture/rgb/**
DS/dataset_capture/rgbd/**
DS/dataset_capture/rgbd_backgrounds/**
!DS/dataset_capture/
!DS/dataset_capture/rgb/
!DS/dataset_capture/rgbd/
!DS/dataset_capture/rgbd_backgrounds/
!DS/dataset_capture/**/.gitkeep

# Offline pre-labeling working dirs (structure only; kept on disk, out of git).
# Includes the in-progress to_review_* folders: the curated dataset lives on
# Hugging Face, so these intermediate review images are not shipped in git.
DS/dataset_prelabel/input_images/**
DS/dataset_prelabel/prelabels_yolo/**
DS/dataset_prelabel/exports_yolo/**
DS/dataset_prelabel/prelabels_sam3/**
DS/dataset_prelabel/synth_render_point/**
DS/dataset_prelabel/synth_render_3dgs/**
DS/dataset_prelabel/composited_views_point/**
DS/dataset_prelabel/composited_views_3dgs/**
DS/dataset_prelabel/to_review_*/**
!DS/dataset_prelabel/**/
!DS/dataset_prelabel/**/.gitkeep

